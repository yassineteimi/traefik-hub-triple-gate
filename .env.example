# =============================================================================
# Traefik Hub - Triple Gate PoC : secrets template
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored) and fill in. Scripts in poc/scripts read this file
# and inject the values as Kubernetes Secrets. NOTHING here is ever committed.
# =============================================================================

# ---- Traefik Hub (Gate platform) -------------------------------------------
# Trial token from https://hub.traefik.io - used by `helm upgrade` to register
# the gateway to your homelab cluster. Must have AI + MCP gateway entitlements.
TRAEFIK_HUB_TOKEN=

# ---- Gate 2: AI Gateway - primary LLM provider (NVIDIA hosted NIM) ----------
# Free key from https://build.nvidia.com (starts with "nvapi-"). OpenAI-compatible
# endpoint, no local GPU required. Serves both chat traffic and the safety guard.
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Primary chat-completion model routed through the AI Gateway.
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
# LLM Guard classifier model. Returns {"User Safety":"safe"|"unsafe"} so Traefik
# Hub's LLM Guard can block on Contains("unsafe"). This is the model used in
# Traefik's official NVIDIA NIMs integration guide. (The reasoning model
# nvidia/nemotron-content-safety-reasoning-4b returns prose, not a verdict, so it
# does NOT fit the guard slot - see docs/prerequisites.md.)
NVIDIA_GUARD_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety

# ---- Gate 2: AI Gateway - failover provider (optional) ----------------------
# Either an OpenAI key, or point at a local Ollama for the failover demo.
OPENAI_API_KEY=
OLLAMA_API_BASE=http://host.docker.internal:11434/v1

# ---- Gate 1 & 3: auth (JWT / OAuth-style) ----------------------------------
# Signing material for the demo JWTs used to exercise auth + TBAC.
# HS256 symmetric secret - injected as Secret apps/jwt (key signingSecret),
# referenced by the JWT Middleware as urn:k8s:secret:jwt:signingSecret.
JWT_SIGNING_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ISSUER=https://triple-gate.local/issuer
JWT_AUDIENCE=triple-gate-poc

# ---- Gate 3: MCP Gateway ----------------------------------------------------
# Location of the MCP server image/repo placed behind Gate 3 (mcp-ecommerce-agent).
MCP_SERVER_IMAGE=
